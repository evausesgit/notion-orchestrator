# --- Notion ---
# Integration token from https://www.notion.so/my-integrations
NOTION_TOKEN=
# Data source ID copied from your Notion database URL
NOTION_DATA_SOURCE_ID=
# Notion API version pinning (default kept up to date with adapter)
NOTION_API_VERSION=2025-09-03
# Optional: JSON object mapping internal role keys to your custom column names
# Example: NOTION_PROPS_JSON={"taskId":"Key","blockedBy":"Depends On"}
NOTION_PROPS_JSON=

# --- Task selection ---
# Sprint name to filter on (leave empty to consider every sprint)
SPRINT_FILTER=
# Status considered ready for pickup
READY_STATUS=Todo
# Name written into "Last Updated By Agent"
AGENT_NAME=notion-orchestrator

# --- Target repo ---
# Required. https or ssh URL
GIT_REPO_URL=
# Branch to clone, commit, and push to
GIT_BRANCH=main
# Personal access token / GitHub App installation token used for auth
GIT_TOKEN=
# Username for HTTPS auth. Leave default for GitHub PATs.
GIT_USERNAME=x-access-token
# Identity used for the commit objects produced by the orchestrator
GIT_AUTHOR_NAME=notion-orchestrator
GIT_AUTHOR_EMAIL=bot@notion-orchestrator.local

# --- Behaviour ---
# Where the target repo gets cloned inside the container
WORKSPACE_DIR=/workspace
# Directory (relative to the cloned repo) where review artifacts are written
REVIEW_ARTIFACT_DIR=.notion-orchestrator/runs
# Comma- or newline-separated commands run when a task supplies none
DEFAULT_VALIDATION_COMMANDS=
# JSON array command used for Execution Mode = agent. The prompt is provided on stdin
# and also written to NOTION_ORCHESTRATOR_PROMPT_FILE.
# Example: AGENT_COMMAND_JSON=["codex","exec","-"]
AGENT_COMMAND_JSON=
# Agent timeout in milliseconds.
AGENT_TIMEOUT_MS=900000
# Set to "true" to allow pushing to GIT_BRANCH. Default: false (safe).
ALLOW_PUSH=false
# Watch-mode backoff cap (seconds)
WATCH_BACKOFF_MAX=300

# --- Logging ---
LOG_FORMAT=text
LOG_LEVEL=info
